# ─── Supabase / PostgreSQL connection ─────────────────────────────────────────
# Copy this file to .env and fill in your real Supabase credentials.
# Find them at: Supabase Dashboard → Your Project → Settings → Database

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase project URL and public anon key (for future direct Supabase client use)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
